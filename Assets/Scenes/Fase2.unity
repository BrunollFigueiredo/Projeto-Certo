  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 16d3d3708e9a6ac48bb53466898d3cb6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  slides:
  - texto: "Este andar opera por produ\xE7\xE3o. A Torre exige que determinada quantidade
      de pe\xE7as seja fabricada dentro do tempo estabelecido. As pe\xE7as t\xEAm
      tamanhos espec\xEDficos. A ordem importa."
  - texto: "Aldric, voc\xEA encontrar\xE1 o painel de configura\xE7\xE3o no n\xEDvel
      superior. Os controles s\xE3o intuitivos para quem foi treinado em opera\xE7\xE3o
      de maquin\xE1rio imperial."
  - texto: "Kofi, o material bruto est\xE1 no andar inferior. Sua fun\xE7\xE3o \xE9
      o transporte at\xE9 a prensa. O painel da prensa indica a sequ\xEAncia exigida."
  - texto: "O cron\xF4metro come\xE7a agora."
  painelCutscene: {fileID: 1500407360}
  textoNarrador: {fileID: 85960170}
  botaoProximo: {fileID: 769385992}
  textoBotaoProximo: {fileID: 579996511}
  cameraCutscene: {fileID: 898825504}
  controlesMobile:
