      m_Calls: []
  m_text: "<b>Tomo dos Candidatos</b>\n\nO Imp\xE9rio de Auris manteve, por gera\xE7\xF5es,
    um registro de candidatos aptos ao servi\xE7o imperial. O crit\xE9rio declarado
    era m\xE9rito. O crit\xE9rio real era origem. De cada grupo avaliado, apenas
    <b>dois</b> nomes eram admitidos, independente do desempenho dos demais. Os dois
    escolhidos recebiam forma\xE7\xE3o, t\xEDtulo e acesso. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
