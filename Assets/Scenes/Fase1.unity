      m_Calls: []
  m_text: "<b>Tomo da Conquista</b>\n\nNo d\xE9cimo ano do reinado de Auris, os generais
    do Conselho Imperial avan\xE7aram sobre as plan\xEDcies de Umbra em tr\xEAs frentes
    simult\xE2neas. A primeira frente cedeu. A segunda recuou. Foi a <b>terceira</b>
    investida, conduzida pelo flanco leste ao amanhecer, que quebrou a resist\xEAncia
    e encerrou a campanha. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
