  m_GameObject: {fileID: 1497710239}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Tomo da Conquista</b>\n\nAntes de qualquer acordo, antes de qualquer
    tratado, houve uma decis\xE3o. O Conselho Imperial reuniu-se em c\xE2mara fechada
    e estabeleceu que o <b>primeiro</b> ato de toda negocia\xE7\xE3o com Umbra seria
    a entrega dos mapas territoriais. Umbra, sem tradi\xE7\xE3o cartogr\xE1fica formal,
    entregou o que p\xF4de."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
